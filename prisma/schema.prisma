generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  createdAt     DateTime           @default(now())
  email         String?            @unique
  emailVerified DateTime?
  image         String?
  name          String?
  accounts      Account[]
  identity      AnonymousIdentity?
  notifications Notification[]
  sessions      Session[]
}

model AnonymousIdentity {
  id               String            @id @default(uuid())
  userId           String            @unique
  username         String            @unique
  avatarKey        String
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatMessages     ChatMessage[]
  chatParticipants ChatParticipant[]
  posts            Post[]
  flags            PostFlag[]
  reactions        Reaction[]
  savedPosts       SavedPost[]
  supportResponses SupportResponse[]
}

model Post {
  id         String            @id @default(uuid())
  identityId String
  content    String
  emotionTag String?
  state      PostState         @default(ACTIVE)
  createdAt  DateTime          @default(now())
  expiresAt  DateTime
  chatRooms  ChatRoom[]
  identity   AnonymousIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  flags      PostFlag[]
  reactions  Reaction[]
  savedPosts SavedPost[]
  responses  SupportResponse[]
}

model Reaction {
  id         String            @id @default(uuid())
  postId     String
  type       String
  createdAt  DateTime          @default(now())
  identityId String
  identity   AnonymousIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  post       Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, identityId])
}

model SupportResponse {
  id         String             @id @default(cuid())
  postId     String
  content    String
  createdAt  DateTime           @default(now())
  identityId String?
  identity   AnonymousIdentity? @relation(fields: [identityId], references: [id], onDelete: Cascade)
  post       Post               @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostFlag {
  id         String            @id @default(uuid())
  postId     String
  reason     String
  createdAt  DateTime          @default(now())
  identityId String
  identity   AnonymousIdentity @relation(fields: [identityId], references: [id])
  post       Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, identityId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  postId     String?
  commentId  String?
  actorLabel String?
  meta       Json?
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedPost {
  id         String            @id @default(uuid())
  identityId String
  postId     String
  createdAt  DateTime          @default(now())
  identity   AnonymousIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  post       Post              @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([identityId, postId])
}

model ChatRoom {
  id           String            @id @default(uuid())
  postId       String
  createdAt    DateTime          @default(now())
  expiresAt    DateTime
  messages     ChatMessage[]
  participants ChatParticipant[]
  post         Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model ChatParticipant {
  id         String            @id @default(uuid())
  roomId     String
  identityId String
  identity   AnonymousIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  room       ChatRoom          @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, identityId])
}

model ChatMessage {
  id         String             @id @default(uuid())
  roomId     String
  content    String
  createdAt  DateTime           @default(now())
  identityId String?
  identity   AnonymousIdentity? @relation(fields: [identityId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  room       ChatRoom           @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

enum PostState {
  ACTIVE
  FADING
  EXPIRED
}

enum NotificationType {
  REACTION
  COMMENT
  MILESTONE
}
